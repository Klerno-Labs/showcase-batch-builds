# Environment Variables Example
# Copy this file to .env.local and fill in the values for your local development

# Optional: Email Service API Key (e.g., SendGrid, Resend, Postmark)
# Required for the contact form to actually send emails.
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Optional: Analytics Tracking ID (e.g., Google Analytics)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Site URL (defaults to localhost:3000 in dev)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000